{
  "description": "DIAC-2359 Send cmr listing notification to legal rep, case officer, home office and appellant sms (remote hearing)",
  "request": {
    "uri": "/asylum/ccdAboutToSubmit",
    "credentials": "SystemUser",
    "input": {
      "id": 60004,
      "eventId": "cmrListing",
      "state": "prepareForHearing",
      "caseData": {
        "template": "minimal-appeal-submitted.json",
        "replacements": {
          "journeyType": "rep",
          "appealReferenceNumber": "PA/12345/2023",
          "ariaListingReference": "LP/12345/2021",
          "legalRepresentativeEmailAddress": "{$TEST_LAW_FIRM_A_USERNAME}",
          "contactPreference": "wantsSms",
          "email": "{$TEST_CITIZEN_USERNAME}",
          "mobileNumber": "{$TEST_CITIZEN_MOBILE}",
          "appellantInDetention": "No",
          "cmrHearingCentre": "taylorHouse",
          "cmrHearingDate": "2023-09-19T10:00:00.000",
          "cmrIsRemoteHearing": "Yes",
          "cmrHearingChannel": {
            "value": {
              "code": "VID",
              "label": "Video"
            },
            "list_items": [
              { "code": "INTER", "label": "In Person" },
              { "code": "NA", "label": "Not in Attendance" },
              { "code": "TEL", "label": "Telephone" },
              { "code": "VID", "label": "Video" }
            ]
          }
        }
      }
    }
  },
  "expectation": {
    "status": 200,
    "errors": [],
    "caseData": {
      "template": "minimal-appeal-submitted.json",
      "replacements": {
        "appealReferenceNumber": "PA/12345/2023",
        "ariaListingReference": "LP/12345/2021",
        "legalRepresentativeEmailAddress": "{$TEST_LAW_FIRM_A_USERNAME}",
        "notificationsSent": [
          {
            "id": "60004_CMR_LISTING_LEGAL_REPRESENTATIVE",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          },
          {
            "id": "60004_CMR_LISTING_CASE_OFFICER",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          },
          {
            "id": "60004_CMR_LISTING_HOME_OFFICE",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          },
          {
            "id": "60004_CMR_LISTING_APPELLANT_SMS",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
