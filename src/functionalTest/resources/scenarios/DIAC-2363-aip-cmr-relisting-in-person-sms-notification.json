{
  "description": "DIAC-2363 Send cmr re-listing notification to case officer, home office and appellant sms for AiP digital appeal (in person hearing)",
  "request": {
    "uri": "/asylum/ccdAboutToSubmit",
    "credentials": "SystemUser",
    "input": {
      "id": 62002,
      "eventId": "cmrReListing",
      "state": "prepareForHearing",
      "caseData": {
        "template": "minimal-appeal-submitted.json",
        "replacements": {
          "journeyType": "aip",
          "appealReferenceNumber": "PA/12345/2023",
          "ariaListingReference": "LP/12345/2021",
          "contactPreference": "wantsSms",
          "subscriptions": [
            {
              "id": "1",
              "value": {
                "subscriber": "appellant",
                "email": "{$TEST_CITIZEN_USERNAME}",
                "wantsEmail": "No",
                "mobileNumber": "{$TEST_CITIZEN_MOBILE}",
                "wantsSms": "Yes"
              }
            }
          ],
          "cmrHearingCentre": "taylorHouse",
          "cmrHearingCentreAddress": {
            "value": {
              "code": "Taylor House Tribunal Hearing Centre, York Road, SE1 7PB",
              "label": "Taylor House Tribunal Hearing Centre, York Road, SE1 7PB"
            }
          },
          "cmrHearingDate": "2023-10-05T10:00:00.000",
          "cmrIsRemoteHearing": "No",
          "cmrHearingChannel": {
            "value": {
              "code": "INTER",
              "label": "In Person"
            },
            "list_items": [
              { "code": "INTER", "label": "In Person" },
              { "code": "NA", "label": "Not in Attendance" },
              { "code": "TEL", "label": "Telephone" },
              { "code": "VID", "label": "Video" }
            ]
          }
        }
      }
    }
  },
  "expectation": {
    "status": 200,
    "errors": [],
    "caseData": {
      "template": "minimal-appeal-submitted.json",
      "replacements": {
        "appealReferenceNumber": "PA/12345/2023",
        "ariaListingReference": "LP/12345/2021",
        "notificationsSent": [
          {
            "id": "62002_CMR_RE_LISTING_CASE_OFFICER",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          },
          {
            "id": "62002_CMR_RE_LISTING_HOME_OFFICE",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          },
          {
            "id": "62002_CMR_RE_LISTING_AIP_APPELLANT_SMS",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          }
        ]
      }
    }
  }
}
