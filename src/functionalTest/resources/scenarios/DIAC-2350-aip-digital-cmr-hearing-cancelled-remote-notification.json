{
  "description": "DIAC-2350 Send cmr cancelled notification to case officer, home office and appellant email and sms for AiP digital appeal (remote hearing)",
  "request": {
    "uri": "/asylum/ccdAboutToSubmit",
    "credentials": "SystemUser",
    "input": {
      "id": 60007,
      "eventId": "cmrHearingCancelled",
      "state": "prepareForHearing",
      "caseData": {
        "template": "minimal-appeal-submitted.json",
        "replacements": {
          "journeyType": "aip",
          "appealReferenceNumber": "PA/12345/2023",
          "ariaListingReference": "LP/12345/2021",
          "contactPreference": "wantsEmail",
          "subscriptions": [
            {
              "id": "1",
              "value": {
                "subscriber": "appellant",
                "email": "{$TEST_CITIZEN_USERNAME}",
                "wantsEmail": "Yes",
                "mobileNumber": "{$TEST_CITIZEN_MOBILE}",
                "wantsSms": "Yes"
              }
            }
          ],
          "cmrHearingCentre": "taylorHouse",
          "cmrHearingDate": "2023-09-19T10:00:00.000",
          "cmrIsRemoteHearing": "Yes",
          "cmrHearingChannel": {
            "value": {
              "code": "VID",
              "label": "Video"
            },
            "list_items": [
              { "code": "INTER", "label": "In Person" },
              { "code": "NA", "label": "Not in Attendance" },
              { "code": "TEL", "label": "Telephone" },
              { "code": "VID", "label": "Video" }
            ]
          }
        }
      }
    }
  },
  "expectation": {
    "status": 200,
    "errors": [],
    "caseData": {
      "template": "minimal-appeal-submitted.json",
      "replacements": {
        "appealReferenceNumber": "PA/12345/2023",
        "ariaListingReference": "LP/12345/2021",
        "notificationsSent": [
          {
            "id": "60007_CMR_CANCELLED_AIP_CASE_OFFICER_EMAIL",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          },
          {
            "id": "60007_CMR_CANCELLED_AIP_HOME_OFFICE_EMAIL",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          },
          {
            "id": "60007_CMR_HEARING_CANCELLED_APPELLANT_AIP_EMAIL",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          },
          {
            "id": "60007_CMR_HEARING_CANCELLED_APPELLANT_AIP_SMS",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          }
        ]
      }
    }
  }
}