{
  "description": "DIAC-149 send NoC notification no legal representative email",
  "request": {
    "uri": "/bail/ccdSubmitted",
    "credentials": "LegalRepresentative",
    "input": {
      "id": 2126,
      "eventId": "nocRequestBail",
      "state": "applicationSubmitted",
      "caseData": {
        "template": "minimal-bail-application-submitted.json",
        "replacements": {
          "hearingCentre": "newport",
          "isLegallyRepresentedForFlag": "Yes",
          "legalRepEmail": ""
        }
      }
    }
  },
  "expectation": {
    "status": 200,
    "errors": [],
    "confirmation": {
      "header": "success",
      "body": "contains([2126_BAIL_NOC_CHANGED_LR_ADMIN,2126_BAIL_NOC_CHANGED_LR_HOME_OFFICE])"
    },
    "notifications": [
      {
        "reference": "2126_BAIL_NOC_CHANGED_LR_HOME_OFFICE",
        "recipient": "{$bailHomeOfficeEmailAddress}",
        "subject": "Bail application: Applicant has a new legal representative",
        "body": [
          "1650-6221-2061-5101",
          "123654LR",
          "John Smith",
          "A12345"
        ]
      },
      {
        "reference": "2126_BAIL_NOC_CHANGED_LR_ADMIN",
        "recipient": "{$bailHearingCentreEmailAddresses.newport}",
        "subject": "Bail application: Applicant has a new legal representative",
        "body": [
          "1650-6221-2061-5101",
          "123654LR",
          "John Smith",
          "A12345"
        ]
      }
    ]
  }
}
