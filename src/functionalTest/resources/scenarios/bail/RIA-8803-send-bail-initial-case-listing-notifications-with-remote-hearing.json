{
  "description": "RIA-8803 Send bail initial case listing notification to HO with remote hearing",
  "request": {
    "uri": "/bail/ccdAboutToSubmit",
    "credentials": "AdminOfficer",
    "input": {
      "id": 2095,
      "eventId": "caseListing",
      "state": "applicationSubmitted",
      "caseData": {
        "template": "bail-application-case-listing.json",
        "replacements": {
          "listingEvent": "initialListing",
          "isBailsLocationReferenceDataEnabled": "Yes",
          "isRemoteHearing": "Yes"
        }
      }
    }
  },
  "expectation": {
    "status": 200,
    "errors": [],
    "caseData": {
      "template": "bail-application-case-listing.json",
      "replacements": {
        "listingEvent": "initialListing",
        "isBailsLocationReferenceDataEnabled": "Yes",
        "isRemoteHearing": "Yes",
        "notificationsSent": [
          {
            "id": "2095_BAIL_UPLOAD_BAIL_SUMMARY_DIRECTION_HOME_OFFICE",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          },
          {
            "id": "2095_BAIL_APPLICATION_CASE_LISTING_HOME_OFFICE",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          }
        ]
      }
    },
    "notifications": [
      {
        "reference": "2095_BAIL_APPLICATION_CASE_LISTING_HOME_OFFICE",
        "recipient": "{$bailHomeOfficeEmailAddress}",
        "subject": "Bail application: Bail hearing listed",
        "body": [
          "1650-6221-2061-5101",
          "John Smith",
          "A12345",
          "1 Jan 2024",
          "Cloud Video Platform (CVP)",
          "10:29"
        ],
        "bodyExclusions": [
          "Newport Tribunal Centre - Columbus House COURT NAME, Langstone Business Park, Newport COURT ADDRESS, NP18 2LX POSTCODE",
          "123654LR",
          "IAC Newport, Columbus House, Langstone Business Park, Chepstow Road, Newport, NP18 2LX"
        ]
      }
    ]
  }
}
