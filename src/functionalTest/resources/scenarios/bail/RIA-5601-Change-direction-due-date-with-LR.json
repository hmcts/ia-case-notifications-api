{
  "description": "RIA-5601 send change direction due date notification to HomeOffice and legal representative",
  "request": {
    "uri": "/bail/ccdAboutToSubmit",
    "credentials": "AdminOfficer",
    "input": {
      "id": 2106,
      "eventId": "changeBailDirectionDueDate",
      "state": "applicationSubmitted",
      "caseData": {
        "template": "minimal-bail-application-submitted.json",
        "replacements": {
          "bailDirectionEditExplanation": "Some explanation for changing the direction due date",
          "bailDirectionEditParties": "Some parties",
          "bailDirectionEditDateDue": "2026-05-12"
        }
      }
    }
  },
  "expectation": {
    "status": 200,
    "errors": [],
    "caseData": {
      "template": "minimal-bail-application-submitted.json",
      "replacements": {
        "bailDirectionEditExplanation": "Some explanation for changing the direction due date",
        "bailDirectionEditParties": "Some parties",
        "bailDirectionEditDateDue": "2026-05-12",
        "notificationsSent": [
          {
            "id": "2106_CHANGE_BAIL_DIRECTION_DUE_DATE_HOME_OFFICE",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          },
          {
            "id": "2106_CHANGE_BAIL_DIRECTION_DUE_DATE_LEGAL_REPRESENTATIVE",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          }
        ]
      }
    },
    "notifications": [
      {
        "reference": "2106_CHANGE_BAIL_DIRECTION_DUE_DATE_HOME_OFFICE",
        "recipient": "{$bailHomeOfficeEmailAddress}",
        "subject": "Bail application: You have a direction",
        "body": [
          "1650-6221-2061-5101",
          "John Smith",
          "A12345",
          "123654LR",
          "12 May 2026",
          "Some explanation for changing the direction due date",
          "Some parties"
        ]
      },
      {
        "reference": "2106_CHANGE_BAIL_DIRECTION_DUE_DATE_LEGAL_REPRESENTATIVE",
        "recipient": "{$TEST_LAW_FIRM_A_USERNAME}",
        "subject": "Bail application: You have a direction",
        "body": [
          "1650-6221-2061-5101",
          "John Smith",
          "A12345",
          "123654LR",
          "12 May 2026",
          "Some explanation for changing the direction due date",
          "Some parties"
        ]
      }
    ]
  }
}
