{
  "description": "RIA-5782 NOC - Stop Representing a client notification",
  "request": {
    "uri": "/bail/ccdSubmitted",
    "credentials": "LegalRepresentative",
    "input": {
      "id": 2104,
      "eventId": "stopLegalRepresenting",
      "state": "applicationSubmitted",
      "caseData": {
        "template": "minimal-bail-application-submitted.json",
        "replacements": {
          "applicantHasMobile": "Yes",
          "applicantMobileNumber1": "{$IA_TEST_APPLICANT_MOBILE}",
          "legalRepCompanyAddress": {
            "AddressLine1": "line1",
            "AddressLine2": "",
            "PostTown": "town",
            "County": "county",
            "PostCode": "NE 2AB",
            "Country": "UK"
          }
        }
      }
    }
  },
  "expectation": {
    "status": 200,
    "errors": [],
    "confirmation": {
      "header": "success",
      "body": "contains([2104_BAIL_STOP_LEGAL_REPRESENTING_ADMIN_OFFICER,2104_BAIL_STOP_LEGAL_REPRESENTING_LEGAL_REP,2104_BAIL_STOP_LEGAL_REPRESENTING_HOME_OFFICE,2104_BAIL_STOP_LEGAL_REPRESENTING_APPLICANT_SMS])"
    },
    "notifications": [
      {
        "reference": "2104_BAIL_STOP_LEGAL_REPRESENTING_ADMIN_OFFICER",
        "recipient": "{$bailHearingCentreEmailAddresses.newport}",
        "subject": "Bail application: Applicant no longer represented",
        "body": [
          "1650-6221-2061-5101",
          "John Smith",
          "A12345",
          "123654LR"
        ]
      },
      {
        "reference": "2104_BAIL_STOP_LEGAL_REPRESENTING_LEGAL_REP",
        "recipient": "{$TEST_LAW_FIRM_A_USERNAME}",
        "subject": "Bail application: You have stopped representing a client",
        "body": [
          "1650-6221-2061-5101",
          "John Smith",
          "A12345",
          "123654LR"
        ]
      },
      {
        "reference": "2104_BAIL_STOP_LEGAL_REPRESENTING_HOME_OFFICE",
        "recipient": "{$bailHomeOfficeEmailAddress}",
        "subject": "Bail application: Applicant no longer represented",
        "body": [
          "1650-6221-2061-5101",
          "John Smith",
          "A12345",
          "123654LR",
          "Legal Rep",
          "{$TEST_LAW_FIRM_A_USERNAME}",
          "line1, town, county, NE 2AB, UK"
        ]
      },
      {
        "reference": "2104_BAIL_STOP_LEGAL_REPRESENTING_APPLICANT_SMS",
        "recipient": "{$IA_TEST_APPLICANT_MOBILE}",
        "subject": "",
        "body": [
          "1650-6221-2061-5101",
          "John Smith",
          "123654LR",
          "2 Feb 2000"
        ]
      }
    ]
  }
}
