{
  "description": "RIA-5965 send NoC notification to legal representative",
  "request": {
    "uri": "/bail/ccdSubmitted",
    "credentials": "LegalRepresentative",
    "input": {
      "id": 5965,
      "eventId": "nocRequestBail",
      "state": "applicationSubmitted",
      "caseData": {
        "template": "minimal-bail-application-submitted.json",
        "replacements": {
          "applicantMobileNumber1": "{$TEST_CITIZEN_MOBILE}",
          "applicantHasMobile": "Yes"
        }
      }
    }
  },
  "expectation": {
    "status": 200,
    "errors": [],
    "confirmation": {
      "header": "success",
      "body": "contains([5965_BAIL_NOC_CHANGED_LR_LEGAL_REPRESENTATIVE,5965_BAIL_NOC_CHANGED_LR_ADMIN,5965_BAIL_NOC_CHANGED_LR_HOME_OFFICE,_BAIL_NOC_CHANGED_LR_APPLICANT_SMS])"
    },
    "notifications": [
      {
        "reference": "5965_BAIL_NOC_CHANGED_LR_HOME_OFFICE",
        "recipient": "{$bailHomeOfficeEmailAddress}",
        "subject": "Bail application: Applicant has a new legal representative",
        "body": [
          "1650-6221-2061-5101",
          "123654LR",
          "John Smith",
          "A12345"
        ]
      },
      {
        "reference": "5965_BAIL_NOC_CHANGED_LR_ADMIN",
        "recipient": "{$bailHearingCentreEmailAddresses.newport}",
        "subject": "Bail application: Applicant has a new legal representative",
        "body": [
          "1650-6221-2061-5101",
          "123654LR",
          "John Smith",
          "A12345"
        ]
      },
      {
        "reference": "5965_BAIL_NOC_CHANGED_LR_LEGAL_REPRESENTATIVE",
        "recipient": "{$TEST_LAW_FIRM_A_USERNAME}",
        "subject": "Bail application: You have stopped representing a client",
        "body": [
          "1650-6221-2061-5101",
          "123654LR",
          "John Smith",
          "A12345"
        ]
      },
      {
        "reference": "5965_BAIL_NOC_CHANGED_LR_APPLICANT_SMS",
        "recipient": "{$TEST_CITIZEN_MOBILE}",
        "subject": "",
        "body": [
          "1650-6221-2061-5101",
          "John Smith",
          "2000-02-02"
        ]
      }
    ]
  }
}
