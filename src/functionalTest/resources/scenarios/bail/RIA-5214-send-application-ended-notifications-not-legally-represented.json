{
  "description": "RIA-5412 send bail application ended notification to Applicant (sms) and HO (emails)",
  "request": {
    "uri": "/bail/ccdAboutToSubmit",
    "credentials": "AdminOfficer",
    "input": {
      "id": 5214,
      "eventId": "endApplication",
      "state": "applicationSubmitted",
      "caseData": {
        "template": "minimal-bail-application-ended.json",
        "replacements": {
          "isLegallyRepresentedForFlag": "No",
          "applicantHasMobile": "Yes",
          "applicantMobileNumber1": "{$IA_TEST_APPLICANT_MOBILE}"
        }
      }
    }
  },
  "expectation": {
    "status": 200,
    "errors": [],
    "caseData": {
      "template": "minimal-bail-application-ended.json",
      "replacements": {
        "isLegallyRepresentedForFlag": "No",
        "applicantHasMobile": "Yes",
        "applicantMobileNumber1": "{$IA_TEST_APPLICANT_MOBILE}",
        "notificationsSent": [
          {
            "id": "5214_BAIL_APPLICATION_ENDED_APPLICANT_SMS",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          },
          {
            "id": "5214_BAIL_APPLICATION_ENDED_HOME_OFFICE",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          }
        ]
      }
    },
    "notifications": [
      {
        "reference": "5214_BAIL_APPLICATION_ENDED_APPLICANT_SMS",
        "recipient": "{$IA_TEST_APPLICANT_MOBILE}",
        "subject": "",
        "body": [
          "1652-2660-6360-5220",
          "ended",
          "2022-05-13"
        ],
        "bodyExclusions": [
          "123654LR"
        ]
      },
      {
        "reference": "5214_BAIL_APPLICATION_ENDED_HOME_OFFICE",
        "recipient": "{$bailHomeOfficeEmailAddress}",
        "subject": "Bail Application: This application has ended",
        "body": [
          "1652-2660-6360-5220",
          "TheName TheLastName",
          "A12345Ended",
          "some reasons for ending the application",
          "ended",
          "13 May 2022"
        ],
        "bodyExclusions": [
          "123654LR"
        ]
      }
    ]
  }
}