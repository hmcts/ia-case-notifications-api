{
  "description": "RIA-5583 send bail application edited submitted notification without LR",
  "request": {
    "uri": "/bail/ccdAboutToSubmit",
    "credentials": "AdminOfficer",
    "input": {
      "id": 5583,
      "eventId": "editBailApplicationAfterSubmit",
      "state": "applicationSubmitted",
      "caseData": {
        "template": "minimal-bail-application-submitted.json",
        "replacements": {
          "applicantHasMobile": "Yes",
          "applicantMobileNumber1": "{$IA_TEST_APPLICANT_MOBILE}"
        }
      }
    }
  },
  "expectation": {
    "status": 200,
    "errors": [],
    "caseData": {
      "template": "minimal-bail-application-submitted.json",
      "replacements": {
        "applicantHasMobile": "Yes",
        "applicantMobileNumber1": "{$IA_TEST_APPLICANT_MOBILE}",
        "notificationsSent": [
          {
            "id": "5583_BAIL_APPLICATION_EDITED_AND_SUBMITTED_HOME_OFFICE",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          },
          {
            "id": "5583_BAIL_APPLICATION_EDITED_AND_SUBMITTED_LEGAL_REP",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          }
        ]
      }
    },
    "notifications": [
      {
        "reference": "5583_BAIL_APPLICATION_EDITED_AND_SUBMITTED_HOME_OFFICE",
        "recipient": "{$bailHomeOfficeEmailAddress}",
        "subject": "Bail application: Application details updated",
        "body": [
          "1650-6221-2061-5101",
          "John Smith",
          "A12345",
          "123654LR"
        ]
      },
      {
        "reference": "5583_BAIL_APPLICATION_EDITED_AND_SUBMITTED_LEGAL_REP",
        "recipient": "{$TEST_LAW_FIRM_A_USERNAME}",
        "subject": "Bail application: Application details updated",
        "body": [
          "1650-6221-2061-5101",
          "John Smith",
          "A12345",
          "123654LR"
        ]
      }
    ]
  }
}
