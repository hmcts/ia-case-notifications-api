{
  "description": "RIA-8198 record decision event for a bail application under IMA with Legal Representative",
  "request": {
    "uri": "/bail/ccdAboutToSubmit",
    "credentials": "Judge",
    "input": {
      "id": 8198,
      "eventId": "recordTheDecision",
      "state": "bailSummaryUploaded",
      "caseData": {
        "template": "minimal-bail-application-submitted.json",
        "replacements": {
          "hoSelectImaStatus": "Yes",
          "recordDecisionType": "granted"
        }
      }
    }
  },
  "expectation": {
    "status": 200,
    "errors": [],
    "caseData": {
      "template": "minimal-bail-application-submitted.json",
      "replacements": {
        "hoSelectImaStatus": "Yes",
        "recordDecisionType": "granted",
        "notificationsSent": [
          {
            "id": "8198_BAIL_RECORD_DECISION_IMA_UPPER_TRIBUNAL",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          }
        ]
      }
    },
    "notifications": [
      {
        "reference": "8198_BAIL_RECORD_DECISION_IMA_UPPER_TRIBUNAL",
        "recipient": "{$bailUpperTribunalEmailAddress}",
        "subject": "Bail application: Access the decision",
        "body": [
          "1650-6221-2061-5101",
          "John Smith",
          "A12345",
          " Granted"
        ],
        "bodyExclusions": [
          "Refused"
        ]
      }
    ]
  }
}