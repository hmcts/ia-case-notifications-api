{
  "description": "RIA-5561 send bail signed decision notice notifications to Applicant (sms) and HO (email)",
  "request": {
    "uri": "/bail/ccdAboutToSubmit",
    "credentials": "Judge",
    "input": {
      "id": 2116,
      "eventId": "uploadSignedDecisionNotice",
      "state": "unsignedDecision",
      "caseData": {
        "template": "minimal-bail-application-submitted.json",
        "replacements": {
          "isLegallyRepresentedForFlag": "No",
          "applicantHasMobile": "Yes",
          "applicantMobileNumber1": "{$IA_TEST_APPLICANT_MOBILE}",
          "recordDecisionType": "refused"
        }
      }
    }
  },
  "expectation": {
    "status": 200,
    "errors": [],
    "caseData": {
      "template": "minimal-bail-application-submitted.json",
      "replacements": {
        "isLegallyRepresentedForFlag": "No",
        "applicantHasMobile": "Yes",
        "applicantMobileNumber1": "{$IA_TEST_APPLICANT_MOBILE}",
        "recordDecisionType": "refused",
        "notificationsSent": [
          {
            "id": "2116_BAIL_SIGNED_DECISION_NOTICE_UPLOADED_APPLICANT_SMS",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          },
          {
            "id": "2116_BAIL_UPLOADED_SIGNED_DECISION_NOTICE_HOME_OFFICE",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          }
        ]
      }
    },
    "notifications": [
      {
        "reference": "2116_BAIL_SIGNED_DECISION_NOTICE_UPLOADED_APPLICANT_SMS",
        "recipient": "{$IA_TEST_APPLICANT_MOBILE}",
        "subject": "",
        "body": [
          "1650-6221-2061-5101",
          "refused"
        ],
        "bodyExclusions": [
          "granted"
        ]
      },
      {
        "reference": "2116_BAIL_UPLOADED_SIGNED_DECISION_NOTICE_HOME_OFFICE",
        "recipient": "{$bailHomeOfficeEmailAddress}",
        "subject": "Bail Application: Access the decision",
        "body": [
          "1650-6221-2061-5101",
          "John Smith",
          "A12345",
          "Refused"
        ],
        "bodyExclusions": [
          "Granted",
          "123654LR"
        ]
      }
    ]
  }
}
