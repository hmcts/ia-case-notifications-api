{
  "description": "RIA-5584 RIA-5454 send bail application submitted notification not legally represented",
  "request": {
    "uri": "/bail/ccdAboutToSubmit",
    "credentials": "AdminOfficer",
    "input": {
      "id": 2110,
      "eventId": "submitApplication",
      "state": "applicationSubmitted",
      "caseData": {
        "template": "minimal-bail-application-submitted.json",
        "replacements": {
          "hearingCentre": "birmingham",
          "isLegallyRepresentedForFlag": "No"
        }
      }
    }
  },
  "expectation": {
    "status": 200,
    "errors": [],
    "caseData": {
      "template": "minimal-bail-application-submitted.json",
      "replacements": {
        "hearingCentre": "birmingham",
        "isLegallyRepresentedForFlag": "No",
        "notificationsSent": [
          {
            "id": "2110_BAIL_APPLICATION_SUBMITTED_HEARING_CENTRE",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          },
          {
            "id": "2110_BAIL_APPLICATION_SUBMITTED_HOME_OFFICE",
            "value": "$/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/"
          }
        ]
      }
    },
    "notifications": [
      {
        "reference": "2110_BAIL_APPLICATION_SUBMITTED_HEARING_CENTRE",
        "recipient": "{$bailHearingCentreEmailAddresses.birmingham}",
        "subject": "Bail application: Application submitted",
        "body": [
          "1650-6221-2061-5101",
          "John Smith",
          "A12345"
        ],
        "bodyExclusions": [
          "123654LR"
        ]
      },
      {
        "reference": "2110_BAIL_APPLICATION_SUBMITTED_HOME_OFFICE",
        "recipient": "{$bailHomeOfficeEmailAddress}",
        "subject": "Bail application: Application submitted",
        "body": [
          "1650-6221-2061-5101",
          "John Smith",
          "A12345"
        ],
        "bodyExclusions": [
          "123654LR"
        ]
      }
    ]
  }
}